# Application
APP_NAME="Cnode EVA"
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/eva

# Public branding
BRAND_NAME=EVA
BRAND_TAGLINE="Verifiable documentary cognitive memory"
BRAND_PRIMARY_COLOR=#151515
BRAND_SECONDARY_COLOR=#090909
BRAND_ACCENT_COLOR=#dfff00
BRAND_LOGO_URL=

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eva
DB_USERNAME=eva_user
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Ingestion
DOCUMENT_MAX_BYTES=10485760

# Safety: real provider calls require both this flag and the explicit --live CLI option.
AI_LIVE_ENABLED=false
AI_REQUEST_TIMEOUT=30
AI_MAX_NEW_SUMMARIES_PER_RUN=5
AI_MAX_OUTPUT_TOKENS=1500
AI_QUERY_MAX_OUTPUT_TOKENS=1800

# Query limits
QUERY_MAX_EVIDENCE=8
QUERY_MAX_INTERACTIONS=20

# Embedding capability
AI_EMBEDDING_PROVIDER=
AI_EMBEDDING_ENDPOINT=
AI_EMBEDDING_MODEL=
AI_EMBEDDING_API_KEY_ENV=EVA_EMBEDDING_API_KEY
AI_EMBEDDING_BATCH_UNITS=64
AI_EMBEDDING_MAX_INPUT_TOKENS=8192
EVA_EMBEDDING_API_KEY=

# Summary capability
AI_SUMMARY_PROVIDER=
AI_SUMMARY_ENDPOINT=
AI_SUMMARY_MODEL=
AI_SUMMARY_API_KEY_ENV=EVA_SUMMARY_API_KEY
EVA_SUMMARY_API_KEY=

# Query-answer capability
AI_QUERY_PROVIDER=
AI_QUERY_ENDPOINT=
AI_QUERY_MODEL=
AI_QUERY_API_KEY_ENV=EVA_QUERY_API_KEY
EVA_QUERY_API_KEY=

# Optional shared language-capability fallback
AI_LANGUAGE_PROVIDER=
AI_LANGUAGE_ENDPOINT=
AI_LANGUAGE_API_KEY_ENV=EVA_LANGUAGE_API_KEY
EVA_LANGUAGE_API_KEY=

# Queue
QUEUE_MAX_FAILURES=3
QUEUE_WORKER_ID=local-worker

# Required for superadmin API access. Generate a unique value of at least 24 characters.
ADMIN_API_TOKEN=

